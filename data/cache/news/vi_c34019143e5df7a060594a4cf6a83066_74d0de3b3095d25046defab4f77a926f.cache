:"";s:15:"descriptionhtml";s:0:"";s:5:"image";s:0:"";s:15:"viewdescription";i:0;s:6:"weight";i:3;s:4:"sort";i:4;s:3:"lev";i:1;s:7:"viewcat";s:16:"viewcat_page_new";s:9:"numsubcat";i:1;s:8:"subcatid";s:1:"8";s:8:"numlinks";i:4;s:6:"newday";i:2;s:8:"featured";i:0;s:12:"ad_block_cat";s:0:"";s:11:"layout_func";s:0:"";s:8:"keywords";s:0:"";s:6:"admins";s:0:"";s:8:"add_time";i:1274987212;s:9:"edit_time";i:1773377388;s:11:"groups_view";s:1:"6";s:6:"status";i:1;}i:8;a:26:{s:5:"catid";i:8;s:8:"parentid";i:6;s:5:"title";s:100:"TRƯỜNG THCS LÝ TỰ TRỌNG ĐẠT GIẢI BA CẤP TỈNH – LAN TỎA HÀNH TRÌNH SỐNG XANH";s:9:"titlesite";s:0:"";s:5:"alias";s:73:"truong-thcs-ly-tu-trong-dat-giai-ba-cap-tinh-lan-toa-hanh-trinh-song-xanh";s:11:"description";s:100:"TRƯỜNG THCS LÝ TỰ TRỌNG ĐẠT GIẢI BA CẤP TỈNH – LAN TỎA HÀNH TRÌNH SỐNG XANH";s:15:"descriptionhtml";s:6700:"<div style="animation-name:none !important;font-family:inherit;text-align:start;transition-property:none !important;" dir="auto">TRƯỜNG THCS LÝ TỰ TRỌNG ĐẠT GIẢI BA CẤP TỈNH – LAN TỎA HÀNH TRÌNH SỐNG XANH</div><div style="animation-name:none !important;font-family:inherit;text-align:start;transition-property:none !important;" dir="auto">Thành tích Giải Ba cấp tỉnh trong Cuộc thi tuyên truyền bảo vệ môi trường năm học 2025–2026 là kết quả xứng đáng cho sự nỗ lực và tinh thần đoàn kết của học sinh Trường THCS Lý Tự Trọng. Trải qua 3 vòng thi, các em đã kiên trì tập luyện, chỉnh sửa nội dung và rèn luyện kỹ năng thuyết trình với quyết tâm cao, thể hiện bản lĩnh và trách nhiệm của học sinh đối với môi trường sống.</div><div style="animation-name:none !important;font-family:inherit;text-align:start;transition-property:none !important;" dir="auto">Quan trọng hơn cả giải thưởng, các em hiểu sâu sắc rằng ô nhiễm nhựa là vấn đề nghiêm trọng và mỗi hành động nhỏ đều có ý nghĩa: giảm nhựa dùng một lần, phân loại rác, tái sử dụng – tái chế. Thành quả hôm nay có được nhờ sự quan tâm, chỉ đạo kịp thời của Ban Giám hiệu, cùng sự hướng dẫn tận tình của tổ chuyên môn.</div><div style="animation-name:none !important;font-family:inherit;text-align:start;transition-property:none !important;" dir="auto"><span style="background-color:rgb(255,255,255);color:rgb(8,8,9);font-family:&#039;Segoe UI Historic&#039;, &#039;Segoe UI&#039;, Helvetica, Arial, sans-serif;font-size:15px;"><span style="-webkit-text-stroke-width:0px;display:inline !important;float:none;font-style:normal;font-variant-caps:normal;font-variant-ligatures:normal;font-weight:400;letter-spacing:normal;orphans:2;text-align:start;text-decoration-color:initial;text-decoration-style:initial;text-decoration-thickness:initial;text-indent:0px;text-transform:none;white-space:pre-wrap;widows:2;word-spacing:0px;">“Chống ô nhiễm nhựa – Vì môi trường xanh – Vì tương lai bền vững!”</span></span></div><div style="animation-name:none !important;font-family:inherit;text-align:start;transition-property:none !important;" dir="auto"><span style="background-color:rgb(255,255,255);color:rgb(8,8,9);font-family:&#039;Segoe UI Historic&#039;, &#039;Segoe UI&#039;, Helvetica, Arial, sans-serif;font-size:15px;"><span style="-webkit-text-stroke-width:0px;display:inline !important;float:none;font-style:normal;font-variant-caps:normal;font-variant-ligatures:normal;font-weight:400;letter-spacing:normal;orphans:2;text-align:start;text-decoration-color:initial;text-decoration-style:initial;text-decoration-thickness:initial;text-indent:0px;text-transform:none;white-space:pre-wrap;widows:2;word-spacing:0px;"><img src="https://scontent.fsgn5-9.fna.fbcdn.net/v/t39.30808-6/604771431_913863250972426_5946281316240655941_n.jpg?stp=dst-jpg_s590x590_tt6&amp;_nc_cat=100&amp;ccb=1-7&amp;_nc_sid=dd6889&amp;_nc_eui2=AeEmTK4OQei_f_JNy8Ugf1BHN4bKIYWSuVg3hsohhZK5WE-coy9OnxkZ1DuqwA83WniFANOc1OdolUZWB_TAhg3g&amp;_nc_ohc=upxs_SMYbaQQ7kNvwHhRb6D&amp;_nc_oc=AdnDkAWQBdirxtpFdMlU44X3qhEaQ62zyVgzifgmmK3alFhy3IpacrcVLFhHBlyyFOHAl2l-HEjdZvHsX7W4AQPQ&amp;_nc_zt=23&amp;_nc_ht=scontent.fsgn5-9.fna&amp;_nc_gid=b7Um